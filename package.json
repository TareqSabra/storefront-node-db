{
  "name": "storefront_backend",
  "version": "0.1.0",
  "description": "",
  "main": "server.ts",
  "scripts": {
    "start": "nodemon --exec ts-node --transpile-only src/server.ts",
    "watch": "tsc-watch --esModuleInterop src/server.ts --outDir ./dist --onSuccess \"node ./dist/server.js\"",
    "test": "jasmine-ts",
    "tsc": "tsc",
    "migrate": "db-migrate up",
    "migrate-down": "db-migrate down",
    "db:create": "docker exec storefront_db psql -U tareq -d storefront -c \"CREATE DATABASE storefront_dev; CREATE DATABASE storefront_test;\""
  },
  "author": "Udacity",
  "license": "ISC",
  "dependencies": {
    "@types/cors": "^2.8.19",
    "bcrypt": "^6.0.0",
    "body-parser": "^1.19.0",
    "cors": "^2.8.6",
    "db-migrate": "^0.11.14",
    "db-migrate-pg": "^1.5.2",
    "dotenv": "^17.4.2",
    "express": "^4.17.1",
    "nodemon": "^3.1.14",
    "pg": "^8.5.1",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^4.17.9",
    "@types/jasmine": "^3.6.3",
    "@types/pg": "^7.14.11",
    "jasmine": "^3.6.4",
    "jasmine-spec-reporter": "^6.0.0",
    "jasmine-ts": "^0.3.0",
    "ts-node": "^10.9.0",
    "tsc-watch": "^4.2.9"
  }
}
