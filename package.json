{
  "name": "storefront_backend",
  "version": "0.1.0",
  "description": "",
  "main": "server.ts",
  "scripts": {
    "dev": "set NODE_ENV=development&& npm start",
    "start": "nodemon --exec ts-node --transpile-only src/server.ts",
    "watch": "tsc-watch --esModuleInterop src/server.ts --outDir ./dist --onSuccess \"node ./dist/server.js\"",
    "test": "set NODE_ENV=test&& db-migrate --env test up && jasmine-ts",
    "test:clean": "set NODE_ENV=test&& db-migrate --env test reset && db-migrate --env test up && jasmine-ts",
    "migrate:dev": "db-migrate --env dev up",
    "migrate:prod": "db-migrate --env prod up",
    "migrate:test": "db-migrate --env test up",
    "migrate:dev-reset": "db-migrate --env dev reset",
    "migrate:prod-reset": "db-migrate --env prod reset",
    "migrate:test-reset": "db-migrate --env test reset",
    "migrate:dev-down": "db-migrate --env dev down",
    "migrate:prod-down": "db-migrate --env prod down",
    "migrate:test-down": "db-migrate --env test down",
    "db:create": "docker exec storefront_db psql -U tareq -d storefront -c \"CREATE DATABASE storefront_dev; CREATE DATABASE storefront_test;\"",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "author": "Udacity",
  "license": "ISC",
  "dependencies": {
    "@types/cors": "^2.8.19",
    "@types/jsonwebtoken": "^9.0.10",
    "bcrypt": "^6.0.0",
    "body-parser": "^1.19.0",
    "cors": "^2.8.6",
    "db-migrate": "^0.11.14",
    "db-migrate-pg": "^1.5.2",
    "dotenv": "^17.4.2",
    "express": "^4.17.1",
    "jsonwebtoken": "^9.0.3",
    "nodemon": "^3.1.14",
    "pg": "^8.5.1",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^4.17.9",
    "@types/jasmine": "^3.6.3",
    "@types/pg": "^7.14.11",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jasmine": "^3.6.4",
    "jasmine-spec-reporter": "^6.0.0",
    "jasmine-ts": "^0.3.0",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.0",
    "tsc-watch": "^4.2.9",
    "typescript-eslint": "^8.59.0"
  }
}
